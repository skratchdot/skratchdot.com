{
  "name": "skratchdot.com",
  "description": "skratchdot.com source code",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://github.com/skratchdot/skratchdot.com",
  "author": "skratchdot",
  "repository": {
    "type": "git",
    "url": "git://github.com/skratchdot/skratchdot.com.git"
  },
  "bugs": {
    "url": "https://github.com/skratchdot/skratchdot.com/issues"
  },
  "scripts": {
    "clean": "rimraf out",
    "dev": "next dev",
    "build": "pnpm run build:feeds && next build && pnpm run build:private && pnpm run build:404 && pnpm run format",
    "build:404": "cp out/404/index.html out/404.html",
    "build:feeds": "node ./_build/feeds.js",
    "build:javadocs": "sh ./_build/javadocs.sh",
    "build:readmes": "node ./_build/readmes.js && pnpm run format",
    "build:private": "cp -R _private/ out/ || :",
    "deploy": "pnpm run clean && pnpm run build && firebase deploy --only hosting",
    "format": "prettier --check --write .",
    "serve": "pnpm dlx serve@latest out",
    "start": "pnpm run dev",
    "lint": "eslint ."
  },
  "keywords": [],
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "cheerio": "^1.2.0",
    "disqus-react": "^1.1.7",
    "eslint": "^9.21.0",
    "eslint-config-next": "^16.2.4",
    "feed": "^5.2.1",
    "firebase-tools": "^15.15.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "marked-gfm-heading-id": "^4.1.4",
    "marked-highlight": "^2.2.4",
    "next": "^16.2.4",
    "node-fetch": "^3.3.2",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-social-icons": "^6.26.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14"
    }
  }
}
