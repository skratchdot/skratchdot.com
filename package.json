{
  "name": "skratchdot.com",
  "description": "skratchdot.com source code",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://github.com/skratchdot/skratchdot.com",
  "author": "skratchdot",
  "repository": {
    "type": "git",
    "url": "git://github.com/skratchdot/skratchdot.com.git"
  },
  "bugs": {
    "url": "https://github.com/skratchdot/skratchdot.com/issues"
  },
  "scripts": {
    "clean": "rimraf out",
    "dev": "next dev",
    "build": "pnpm run build:feeds && next build && pnpm run build:private && pnpm run build:404",
    "build:404": "cp out/404/index.html out/404.html",
    "build:feeds": "node ./_build/feeds.js",
    "build:javadocs": "sh ./_build/javadocs.sh",
    "build:readmes": "node ./_build/readmes.js && pnpm run format",
    "build:private": "cp -R _private/ out/ || :",
    "deploy": "pnpm run clean && pnpm run build && firebase deploy --only hosting",
    "format": "prettier --check --write .",
    "serve": "pnpm dlx serve@latest out",
    "start": "pnpm run dev",
    "lint": "eslint ."
  },
  "keywords": [],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@typescript-eslint/parser": "^8.61.1",
    "cheerio": "^1.2.0",
    "disqus-react": "^1.1.7",
    "eslint": "^10.5.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-config-next": "^16.2.9",
    "feed": "^5.2.1",
    "firebase-tools": "^15.22.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-gfm-heading-id": "^4.1.4",
    "marked-highlight": "^2.2.4",
    "next": "^16.2.9",
    "node-fetch": "^3.3.2",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-social-icons": "^6.26.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
